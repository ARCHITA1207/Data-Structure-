#include<stdio.h>
int main() {
	int arr[100];
	int n,found=0,key;
	scanf("%d",&n);
	for(int i=0;i<n; i++) {
		scanf("%d",&arr[i]);
	}
	scanf("%d",&key);
	int low=0,high=n-1;
	while(low<=high) {
		mid=(low+high)/2;
		if(arr[mid]==key) {
			found=1;
			printf("ELEMENT FOUND AT POSITION %d",mid+1);
			break;
		}
		else if(key<arr[mid]) {
			high=mid-1;
		}
		else {
			low=mid+1;
		}
	}
	if(found==0) {
		printf("ELEMENT NOT FOUNd");
	}
}
