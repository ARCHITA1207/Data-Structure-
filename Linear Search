#include <stdio.h>
int main()
{   int arr[100];
    int n,found=0,key;
    scanf("%d",&n);
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
    scanf("%d",&key);
     for(int i=0;i<n;i++){
        if(arr[i]==key){
            found =1;
            break;
        }
    }
    if(found){
        printf("yes");
    }
    else{
        printf("no");
    }
    return 0;
}
